#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"
data_home="${XDG_DATA_HOME:-${HOME}/.local/share}"
config_home="${XDG_CONFIG_HOME:-${HOME}/.config}"
bin_dir="${INSTALL_BIN_DIR:-${HOME}/.local/bin}"
data_dir="${data_home}/ublue-github-runner"
config_dir="${config_home}/ublue-github-runner"
wrapper_path="${bin_dir}/ujust"
wrapper_marker="# managed by ublue-github-runner"

die() {
  echo "$*" >&2
  exit 1
}

install_file() {
  local src="$1"
  local dst="$2"
  local mode="$3"

  install -D -m "${mode}" "${src}" "${dst}"
}

ensure_wrapper_target() {
  if [[ -e "${wrapper_path}" ]] && ! grep -qF "${wrapper_marker}" "${wrapper_path}"; then
    die "${wrapper_path} already exists and is not managed by this project"
  fi
}

mkdir -p "${data_dir}" "${config_dir}" "${bin_dir}"
ensure_wrapper_target

install_file "${repo_root}/assets/compose.yaml" "${data_dir}/compose.yaml" 0644
install_file "${repo_root}/assets/Dockerfile.runner" "${data_dir}/Dockerfile.runner" 0644
install_file "${repo_root}/assets/runner-entrypoint.sh" "${data_dir}/runner-entrypoint.sh" 0755
install_file "${repo_root}/assets/runner" "${data_dir}/runner" 0755
install_file "${repo_root}/assets/ujust.just" "${config_dir}/ujust.just" 0644

cat > "${wrapper_path}" <<EOF
#!/usr/bin/env bash
set -euo pipefail
${wrapper_marker}

justfile="\${XDG_CONFIG_HOME:-\${HOME}/.config}/ublue-github-runner/ujust.just"

if [[ ! -f "\${justfile}" ]]; then
  exec /usr/bin/ujust "\$@"
fi

exec just --justfile "\${justfile}" "\$@"
EOF
chmod 0755 "${wrapper_path}"

echo "Installed user-space ujust extension"
echo "Data: ${data_dir}"
echo "Config: ${config_dir}"
echo "Wrapper: ${wrapper_path}"

if ! printf '%s\n' "${PATH}" | tr ':' '\n' | grep -Fx "${bin_dir}" >/dev/null; then
  echo "Warning: ${bin_dir} is not in PATH; run ${wrapper_path} directly or update your shell PATH." >&2
fi
