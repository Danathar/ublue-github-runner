#!/usr/bin/env bash
set -euo pipefail

share_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
config_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/ublue-github-runner"
config_file="${config_dir}/runner.env"

die() {
  echo "$*" >&2
  exit 1
}

# Keep the saved config format deliberately simple:
# each line is just KEY=value with no shell syntax.
# That makes the file easier to read and safer to parse.
config_line() {
  local key="$1"
  local value="$2"

  case "${value}" in
    *$'\n'*|*$'\r'*)
      die "Config value for ${key} cannot contain newlines"
      ;;
  esac

  printf '%s=%s\n' "${key}" "${value}"
}

repo_slug() {
  if [[ -n "${GITHUB_REPOSITORY:-}" ]]; then
    printf '%s\n' "${GITHUB_REPOSITORY,,}" | tr '/._' '-'
  else
    hostname -s
  fi
}

trim_label() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "${value}"
}

allowed_config_key() {
  case "${1}" in
    GITHUB_REPOSITORY|RUNNER_NAME|RUNNER_LABELS|RUNNER_HOME|RUNNER_CONTAINER_NAME|RUNNER_IMAGE_NAME)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

set_config_value() {
  local key="$1"
  local value="$2"

  allowed_config_key "${key}" || die "Unsupported key in ${config_file}: ${key}"

  export "${key}=${value}"
}

load_env() {
  local line
  local key
  local value

  if [[ -f "${config_file}" ]]; then
    while IFS= read -r line; do
      [[ -n "${line}" ]] || continue
      [[ "${line}" == \#* ]] && continue
      [[ "${line}" == *=* ]] || die "Invalid line in ${config_file}: ${line}"

      key="${line%%=*}"
      value="${line#*=}"
      [[ -n "${key}" ]] || continue

      if [[ -z "${!key+x}" ]]; then
        # Only load the handful of keys this tool owns.
        # The file is treated as data, not as shell code.
        set_config_value "${key}" "${value}"
      fi
    done < "${config_file}"
  fi
}

set_defaults() {
  local slug

  export RUNNER_HOME="${RUNNER_HOME:-${HOME}/.local/share/github-actions-runner}"
  export RUNNER_INSTALL_DIR="${RUNNER_INSTALL_DIR:-${RUNNER_HOME}/actions-runner}"
  export RUNNER_WORKDIR="${RUNNER_WORKDIR:-${RUNNER_HOME}/work}"
  export RUNNER_TOOLCACHE_DIR="${RUNNER_TOOLCACHE_DIR:-${RUNNER_HOME}/toolcache}"
  export RUNNER_NAME="${RUNNER_NAME:-github-runner-$(hostname -s)}"
  export RUNNER_LABELS="${RUNNER_LABELS:-self-hosted,linux,x64}"
  export REPO_URL="${REPO_URL:-}"
  slug="$(repo_slug)"
  export RUNNER_CONTAINER_NAME="${RUNNER_CONTAINER_NAME:-github-actions-runner-${slug}}"
  export RUNNER_IMAGE_NAME="${RUNNER_IMAGE_NAME:-local/github-actions-runner:${slug}}"

  if [[ -n "${GITHUB_REPOSITORY:-}" && -z "${REPO_URL}" ]]; then
    export REPO_URL="https://github.com/${GITHUB_REPOSITORY}"
  fi
}

require_repo_config() {
  [[ -n "${GITHUB_REPOSITORY:-}" ]] || die "GITHUB_REPOSITORY is required"
  [[ "${GITHUB_REPOSITORY}" == */* ]] || die "GITHUB_REPOSITORY must be in owner/repo format"
}

require_docker() {
  command -v docker >/dev/null || die "docker is required"
  docker version >/dev/null
  docker compose version >/dev/null
}

require_gh() {
  command -v gh >/dev/null || die "gh is required"
  gh auth status >/dev/null
}

container_name() {
  printf '%s\n' "${RUNNER_CONTAINER_NAME}"
}

compose() {
  docker compose \
    --file "${share_dir}/compose.yaml" \
    --project-directory "${share_dir}" \
    "$@"
}

compose_runner_exists() {
  [[ -n "$(compose ps --all --quiet runner 2>/dev/null)" ]]
}

ensure_dirs() {
  mkdir -p \
    "${RUNNER_INSTALL_DIR}" \
    "${RUNNER_WORKDIR}" \
    "${RUNNER_TOOLCACHE_DIR}"
}

container_exists() {
  docker container inspect "$(container_name)" >/dev/null 2>&1
}

container_running() {
  [[ "$(docker inspect -f '{{.State.Running}}' "$(container_name)" 2>/dev/null || true)" == "true" ]]
}

registration_token() {
  local token

  # Keep the error message human-readable here.
  # Raw GitHub API JSON is useful for debugging, but it is a poor default
  # experience for users who only need to know what to fix next.
  if ! token="$(gh api -X POST "repos/${GITHUB_REPOSITORY}/actions/runners/registration-token" --jq .token 2>/dev/null)"; then
    die "Failed to get a runner registration token for ${GITHUB_REPOSITORY}. Check 'gh auth status' and make sure the authenticated account can manage self-hosted runners for this repository."
  fi

  [[ -n "${token}" ]] || die "GitHub returned an empty runner registration token for ${GITHUB_REPOSITORY}"
  printf '%s\n' "${token}"
}

runner_id() {
  gh api --paginate "repos/${GITHUB_REPOSITORY}/actions/runners" \
    --jq '.runners[] | select(.name == env.RUNNER_NAME) | .id' \
    | head -n 1
}

show_github_status() {
  local runner_status

  runner_status="$(
    gh api --paginate "repos/${GITHUB_REPOSITORY}/actions/runners" \
      --jq '.runners[] | select(.name == env.RUNNER_NAME) | {name: .name, status: .status, busy: .busy, labels: [.labels[].name]}' \
      || true
  )"

  if [[ -n "${runner_status}" ]]; then
    echo "${runner_status}"
  else
    echo "Runner ${RUNNER_NAME} is not registered in ${GITHUB_REPOSITORY}"
  fi
}

render_effective_config() {
  cat <<EOF
Repository: ${GITHUB_REPOSITORY:-unset}
Repo URL: ${REPO_URL:-unset}
Runner name: ${RUNNER_NAME}
Runner labels: ${RUNNER_LABELS}
Runner home: ${RUNNER_HOME}
Runner install dir: ${RUNNER_INSTALL_DIR}
Runner workdir: ${RUNNER_WORKDIR}
Runner toolcache dir: ${RUNNER_TOOLCACHE_DIR}
Runner container name: ${RUNNER_CONTAINER_NAME}
Runner image name: ${RUNNER_IMAGE_NAME}
Config file: ${config_file}
Share directory: ${share_dir}
EOF
}

show_config() {
  load_env
  set_defaults
  render_effective_config
}

save_config() {
  mkdir -p "${config_dir}"
  cat > "${config_file}" <<EOF
# User configuration for the local GitHub Actions runner.
# This file intentionally uses plain KEY=value lines.
# It is read by this tool as data, not executed as shell code.
$(config_line "GITHUB_REPOSITORY" "${GITHUB_REPOSITORY}")
$(config_line "RUNNER_NAME" "${RUNNER_NAME}")
$(config_line "RUNNER_LABELS" "${RUNNER_LABELS}")
$(config_line "RUNNER_HOME" "${RUNNER_HOME}")
$(config_line "RUNNER_CONTAINER_NAME" "${RUNNER_CONTAINER_NAME}")
$(config_line "RUNNER_IMAGE_NAME" "${RUNNER_IMAGE_NAME}")
EOF
}

unregister_runner() {
  local id

  id="$(runner_id)"
  if [[ -z "${id}" ]]; then
    echo "Runner ${RUNNER_NAME} is not registered in ${GITHUB_REPOSITORY}"
    return 0
  fi

  gh api -X DELETE "repos/${GITHUB_REPOSITORY}/actions/runners/${id}" >/dev/null
  echo "Unregistered ${RUNNER_NAME} from ${GITHUB_REPOSITORY}"
}

usage() {
  cat <<'EOF'
Usage: ublue-github-runner <prompt|help|configure|configure-from-env|doctor|install|remove|status|logs|example|show-config>
EOF
}

prompt() {
  local action

  if command -v gum >/dev/null 2>&1; then
    action="$(gum choose configure configure-from-env install remove status logs doctor example show-config help)"
  elif command -v fzf >/dev/null 2>&1; then
    action="$(printf '%s\n' configure configure-from-env install remove status logs doctor example show-config help | fzf --prompt='setup-github-runner > ')"
  else
    help
    return 0
  fi

  [[ -n "${action}" ]] || return 0
  main "${action}"
}

help() {
  cat <<'EOF'
setup-github-runner actions:
  configure Prompt for repo and runner settings, then save them locally
  configure-from-env Save configuration from current environment variables
  install   Build and start the repo-scoped runner
  remove    Stop the runner and unregister it from GitHub
  status    Show local system, container, config, and GitHub runner status
  logs      Follow runner logs
  doctor    Verify Docker, boot persistence, path, and GitHub access
  example   Print a step-by-step example for the configured repository
  show-config Print the resolved effective configuration
EOF
}

prompt_value() {
  local prompt_label="$1"
  local current_value="$2"
  local placeholder="$3"
  local value

  if command -v gum >/dev/null 2>&1; then
    value="$(gum input --prompt "${prompt_label}: " --value "${current_value}" --placeholder "${placeholder}")"
  else
    read -r -p "${prompt_label} [${current_value}]: " value
  fi

  if [[ -n "${value}" ]]; then
    printf '%s\n' "${value}"
  else
    printf '%s\n' "${current_value}"
  fi
}

configure() {
  local repository
  local runner_name
  local runner_labels
  local runner_home
  local runner_container_name
  local runner_image_name

  load_env
  set_defaults

  repository="$(prompt_value "GitHub repository" "${GITHUB_REPOSITORY:-owner/repo}" "owner/repo")"
  [[ "${repository}" == */* ]] || die "GITHUB_REPOSITORY must be in owner/repo format"
  export GITHUB_REPOSITORY="${repository}"
  set_defaults

  runner_name="$(prompt_value "Runner name" "${RUNNER_NAME}" "github-runner-$(hostname -s)")"
  runner_labels="$(prompt_value "Runner labels" "${RUNNER_LABELS}" "self-hosted,linux,x64")"
  runner_home="$(prompt_value "Runner home" "${RUNNER_HOME}" "${HOME}/.local/share/github-actions-runner")"
  export RUNNER_HOME="${runner_home}"
  set_defaults
  runner_container_name="$(prompt_value "Runner container name" "${RUNNER_CONTAINER_NAME}" "github-actions-runner-$(repo_slug)")"
  runner_image_name="$(prompt_value "Runner image name" "${RUNNER_IMAGE_NAME}" "local/github-actions-runner:$(repo_slug)")"

  export RUNNER_NAME="${runner_name}"
  export RUNNER_LABELS="${runner_labels}"
  export RUNNER_HOME="${runner_home}"
  export RUNNER_CONTAINER_NAME="${runner_container_name}"
  export RUNNER_IMAGE_NAME="${runner_image_name}"
  set_defaults
  save_config

  echo "Saved runner configuration to ${config_file}"
  render_effective_config
}

configure_from_env() {
  load_env
  require_repo_config
  set_defaults
  save_config
  echo "Saved runner configuration to ${config_file}"
  render_effective_config
}

doctor() {
  local local_bin_dir="${HOME}/.local/bin"
  local token_status="failed"

  load_env
  set_defaults
  require_repo_config
  require_docker
  require_gh
  ensure_dirs

  if registration_token >/dev/null 2>&1; then
    token_status="ok"
  fi

  echo "doctor:"
  echo "  docker cli: ok"
  echo "  docker compose: ok"
  echo "  gh auth: ok"
  echo "  repo configuration: ok"
  echo "  runner registration token: ${token_status}"
  if command -v systemctl >/dev/null 2>&1; then
    echo "  docker.service enabled: $(systemctl is-enabled docker.service 2>/dev/null || echo unknown)"
    echo "  docker.service active: $(systemctl is-active docker.service 2>/dev/null || echo unknown)"
  fi
  if printf '%s\n' "${PATH}" | tr ':' '\n' | grep -Fx "${local_bin_dir}" >/dev/null; then
    echo "  ~/.local/bin in PATH: yes"
  else
    echo "  ~/.local/bin in PATH: no"
  fi
  echo
  render_effective_config
}

install() {
  load_env
  set_defaults
  require_repo_config
  require_docker
  require_gh
  ensure_dirs

  # Fetch the token before touching the current container so we do not
  # tear down a working runner if GitHub auth is broken.
  export RUNNER_TOKEN
  RUNNER_TOKEN="$(registration_token)"

  # Always let Docker Compose reconcile the service.
  # Recreating the container is the simplest way to apply config changes
  # such as new labels, names, paths, or image settings.
  if compose_runner_exists; then
    echo "Recreating the runner container so configuration changes take effect"
    compose down
  fi

  # Auto-update is disabled inside the runner container, so the easiest
  # understandable update story is: run install again.
  # We pull the latest upstream base image, rebuild our thin wrapper image,
  # and then start the service with the current saved configuration.
  compose build --pull
  compose up --detach
  status
}

remove() {
  local gh_ready=0

  load_env
  set_defaults
  require_docker

  if [[ -n "${GITHUB_REPOSITORY:-}" ]] \
    && [[ "${GITHUB_REPOSITORY}" == */* ]] \
    && command -v gh >/dev/null \
    && gh auth status >/dev/null 2>&1; then
    gh_ready=1
  fi

  if (( gh_ready )); then
    unregister_runner
  else
    echo "Skipping GitHub unregister; run configure and authenticate gh to remove the runner registration." >&2
  fi

  if container_exists; then
    compose down
  else
    echo "Runner container is not present"
  fi
}

status() {
  local gh_ready=0
  local container_restart="missing"
  local container_state="missing"
  local container_image="missing"

  load_env
  set_defaults
  require_docker

  echo "local:"
  if command -v systemctl >/dev/null 2>&1; then
    echo "  docker.service enabled: $(systemctl is-enabled docker.service 2>/dev/null || echo unknown)"
    echo "  docker.service active: $(systemctl is-active docker.service 2>/dev/null || echo unknown)"
  fi
  if container_exists; then
    container_restart="$(docker inspect -f '{{.HostConfig.RestartPolicy.Name}}' "$(container_name)")"
    container_state="$(docker inspect -f '{{.State.Status}}' "$(container_name)")"
    container_image="$(docker inspect -f '{{.Config.Image}}' "$(container_name)")"
  fi
  echo "  container name: $(container_name)"
  echo "  container state: ${container_state}"
  echo "  container restart policy: ${container_restart}"
  echo "  container image: ${container_image}"
  echo
  echo "config:"
  render_effective_config
  echo
  echo "compose:"
  compose ps

  if [[ -n "${GITHUB_REPOSITORY:-}" ]] \
    && [[ "${GITHUB_REPOSITORY}" == */* ]] \
    && command -v gh >/dev/null \
    && gh auth status >/dev/null 2>&1; then
    gh_ready=1
  fi

  if (( gh_ready )); then
    echo
    echo "github:"
    show_github_status
  else
    echo "GitHub status unavailable; run configure and authenticate gh to query the runner." >&2
  fi
}

yaml_runs_on_list() {
  local labels=()
  local label
  local first=1

  IFS=',' read -r -a labels <<< "${RUNNER_LABELS}"
  printf '['
  for label in "${labels[@]}"; do
    label="$(trim_label "${label}")"
    [[ -n "${label}" ]] || continue
    if (( first )); then
      first=0
    else
      printf ', '
    fi
    printf '%s' "${label}"
  done
  printf ']'
}

example() {
  load_env
  set_defaults
  require_repo_config

  cat <<EOF
Worked example for ${GITHUB_REPOSITORY}

1. Install the user-space ujust extension:
   sudo systemctl enable --now docker.service
   just install-user

2. Configure the runner:
   ujust setup-github-runner configure

   Suggested answers:
   - GitHub repository: ${GITHUB_REPOSITORY}
   - Runner name: ${RUNNER_NAME}
   - Runner labels: ${RUNNER_LABELS}
   - Runner home: ${RUNNER_HOME}
   - Runner container name: ${RUNNER_CONTAINER_NAME}
   - Runner image name: ${RUNNER_IMAGE_NAME}

3. Verify prerequisites:
   ujust setup-github-runner doctor

4. Install and start the runner:
   ujust setup-github-runner install

5. Check status:
   ujust setup-github-runner status

6. Point trusted workflow jobs at the runner with:

   runs-on: $(yaml_runs_on_list)

This tool does not edit ${GITHUB_REPOSITORY}'s workflow YAML for you.
Keep public pull_request jobs on GitHub-hosted runners unless you explicitly
want untrusted code running on your own machine.
EOF
}

logs() {
  load_env
  set_defaults
  require_docker
  compose logs --follow runner
}

main() {
  case "${1:-}" in
    prompt|"")
      prompt
      ;;
    help)
      help
      ;;
    configure)
      configure
      ;;
    configure-from-env)
      configure_from_env
      ;;
    doctor)
      doctor
      ;;
    install|up)
      install
      ;;
    remove|down)
      remove
      ;;
    status)
      status
      ;;
    logs)
      logs
      ;;
    example)
      example
      ;;
    show-config)
      show_config
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
