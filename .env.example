# Repo-scoped defaults
RUNNER_SCOPE=repo
GITHUB_REPOSITORY=owner/repo
REPO_URL=https://github.com/owner/repo

# Optional runner identity overrides
RUNNER_NAME=github-runner-hostname
RUNNER_LABELS=self-hosted,linux,x64
RUNNER_CONTAINER_NAME=github-actions-runner
RUNNER_IMAGE_NAME=local/github-actions-runner:bluefin

# Store runner state outside the immutable root filesystem
RUNNER_HOME=$HOME/.local/share/github-actions-runner
RUNNER_INSTALL_DIR=$RUNNER_HOME/actions-runner
RUNNER_WORKDIR=$RUNNER_HOME/work
RUNNER_TOOLCACHE_DIR=$RUNNER_HOME/toolcache

# Org-scoped alternative
# RUNNER_SCOPE=org
# GITHUB_ORG=example-org
